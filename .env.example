# Copy to .env and fill in real values. NEVER commit the real .env.

# ── Core ──────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ORIGIN_ALLOW_ALL=False

# ── Application database (managed models — migrations run here) ────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=hf_group_app
DB_USER=postgres
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432

# ── Legacy data warehouse (unmanaged/read-only models) ────────────
DW_ENGINE=django.db.backends.postgresql
DW_NAME=datawarehouse
DW_USER=datawarehouse
DW_PASSWORD=
DW_HOST=
DW_PORT=5432

# ── Cache / queue ─────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── Email (OTP / password reset) ──────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── AI ────────────────────────────────────────────────────────────
# Required for the AI assistant to answer; without it the agent replies "not configured".
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── JWT token lifetimes (days) ────────────────────────────────────
ACCESS_TOKEN_LIFETIME_DAYS=1
REFRESH_TOKEN_LIFETIME_DAYS=7
